# Browser WebSocket endpoint used by Vite.
VITE_WS_URL=ws://localhost:8080

# Online game server port.
PORT=8080

# Keep this secret on the game server. Never prefix it with VITE_.
GEMINI_API_KEY=replace_with_a_new_rotated_key

# Official conversational Live model default. Override only with a model enabled for your project.
GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview

# Text dialogue and quest reasoning model.
GEMINI_TEXT_MODEL=gemini-3.5-flash

# Comma-separated browser origins allowed to request short-lived voice tokens.
ALLOWED_ORIGINS=http://localhost:5173

# Daily per-player budgets. Production stores counters by PUREFXAI ID in PostgreSQL.
DAILY_TEXT_TOKEN_LIMIT=20000
DAILY_VOICE_MINUTES=30
DAILY_AUTO_FARM_MINUTES=120
